@{ ViewData["Title"] = "Login"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="header" style="text-align:center; padding: 32px 24px 28px;">
    <div style="font-size:3rem; margin-bottom:10px;">⚽</div>
        <div class="header-title" style="font-size:1.6rem;">Mundial 2026</div>
            <div class="header-sub">Iniciá sesión para continuar</div>
            </div>
            <div class="header-strip"></div>

            <div class="container">
                <div class="form-box">
                        <div class="form-title">Iniciar Sesión</div>

                                @if (ViewBag.Error != null)
                                        {
                                                    <div class="alerta-error">@ViewBag.Error</div>
                                                            }

                                                                    <form method="post">
                                                                                <div class="form-group">
                                                                                                <label>Email</label>
                                                                                                                <input type="email" name="email" placeholder="tucorreo@email.com" required />
                                                                                                                            </div>
                                                                                                                                        <div class="form-group">
                                                                                                                                                        <label>Contraseña</label>
                                                                                                                                                                        <input type="password" name="password" placeholder="••••••••" required />
                                                                                                                                                                                    </div>
                                                                                                                                                                                                <button type="submit" class="btn-primary">Ingresar</button>
                                                                                                                                                                                                        </form>

                                                                                                                                                                                                                <form method="get" action="/Auth/Registro">
                                                                                                                                                                                                                            <button type="submit" class="btn-secondary">
                                                                                                                                                                                                                                            ¿No tenés cuenta? <span>Registrate</span>
                                                                                                                                                                                                                                                        </button>
                                                                                                                                                                                                                                                                </form>
                                                                                                                                                                                                                                                                    </div>
                                                                                                                                                                                                                                                                    </div>