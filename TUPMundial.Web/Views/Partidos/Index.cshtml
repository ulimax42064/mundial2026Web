@model List<TUPMundial.Web.Models.Partido>
@{ ViewData["Title"] = "Partidos"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="header">
    <div class="header-row">
        <div class="header-left">
            <span style="font-size:2rem;">⚽</span>
            <div>
                <div class="header-title">Mundial 2026</div>
                <div class="header-sub">Hola, @ViewBag.Nombre 👋</div>
            </div>
        </div>
        <div style="display:flex; flex-direction:column; align-items:flex-end; gap:8px;">
            <a href="/Auth/Logout"><button class="btn-salir">Salir</button></a>
            <a href="/Tickets" class="mis-tickets-link">🎟 Mis tickets</a>
        </div>
    </div>
</div>
<div class="header-strip"></div>

<!-- Filtros -->
<div class="filtros">
    <a href="/Partidos">
        <button class="filtro-btn @(ViewBag.GrupoSel == "Todos" ? "activo" : "")">Todos</button>
    </a>
    @foreach (var g in ViewBag.Grupos as List<string>)
    {
        <a href="/Partidos?grupo=@g">
            <button class="filtro-btn @(ViewBag.GrupoSel == g ? "activo" : "")">@g</button>
        </a>
    }
</div>

<!-- Lista -->
<div class="container" style="padding-top:8px;">
    @foreach (var p in Model)
    {
        <a href="/Partidos/Detalle/@p.Id">
            <div class="partido-card">
                <div>
                    <div class="partido-grupo">@p.Grupo</div>
                    <div class="partido-equipos">@p.Flag1 @p.Equipo1 vs @p.Equipo2 @p.Flag2</div>
                    <div class="partido-info">
                        📅 @p.Fecha<br />
                        🏟 @p.Estadio
                    </div>
                </div>
                <div class="partido-arrow">›</div>
            </div>
        </a>
    }
</div>