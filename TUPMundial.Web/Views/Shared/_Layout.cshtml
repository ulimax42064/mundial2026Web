<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mundial 2026</title>
    <style>
        :root { --verde-oscuro:#1B5E20; --verde-medio:#2E7D32; --dorado:#FFC107; --dorado-dark:#F57F17; --fondo:#121212; --tarjeta:#1E1E1E; --tarjeta-hover:#252525; --texto:#FFFFFF; --texto-muted:rgba(255,255,255,0.6); }
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
        body{font-family:'Segoe UI',sans-serif;background:var(--fondo);color:var(--texto);min-height:100vh;}
        a{text-decoration:none;color:inherit;}
        .header{background:linear-gradient(to bottom,var(--verde-oscuro),var(--verde-medio));padding:16px 20px 20px;}
        .header-strip{height:3px;background:linear-gradient(to right,var(--dorado),var(--dorado-dark),var(--dorado));}
        .header-row{display:flex;align-items:center;justify-content:space-between;}
        .header-left{display:flex;align-items:center;gap:12px;}
        .header-title{font-size:1.3rem;font-weight:800;color:#fff;}
        .header-sub{font-size:0.85rem;color:rgba(255,255,255,0.7);}
        .btn-salir{background:transparent;border:1.5px solid var(--dorado);color:var(--dorado);padding:6px 14px;border-radius:20px;font-weight:700;cursor:pointer;font-size:0.85rem;}
        .mis-tickets-link{color:var(--dorado);font-size:0.85rem;font-weight:700;background:rgba(255,193,7,0.1);border:1px solid var(--dorado);border-radius:20px;padding:6px 14px;display:inline-block;margin-top:8px;}
        .container{max-width:480px;margin:0 auto;padding:20px 16px;}
        .form-box{background:var(--tarjeta);border-radius:16px;padding:28px 24px;margin-top:24px;}
        .form-title{font-size:1.25rem;font-weight:700;margin-bottom:20px;}
        .form-group{margin-bottom:14px;}
        .form-group label{display:block;font-size:0.8rem;color:var(--texto-muted);margin-bottom:6px;}
        .form-group input{width:100%;background:#2a2a2a;border:1.5px solid rgba(255,255,255,0.15);border-radius:8px;padding:12px 14px;color:var(--texto);font-size:0.95rem;outline:none;}
        .form-group input:focus{border-color:var(--dorado);}
        .btn-primary{width:100%;background:var(--dorado);color:var(--fondo);border:none;border-radius:12px;padding:14px;font-size:1rem;font-weight:700;cursor:pointer;margin-top:8px;}
        .btn-secondary{width:100%;background:transparent;color:var(--texto-muted);border:none;padding:12px;font-size:0.88rem;cursor:pointer;margin-top:4px;}
        .btn-secondary span{color:var(--dorado);font-weight:700;}
        .alerta-error{background:#4E0000;color:#EF9A9A;border-radius:8px;padding:12px 14px;font-size:0.85rem;margin-bottom:14px;}
        .alerta-ok{background:#1B5E20;color:#A5D6A7;border-radius:8px;padding:16px;font-size:0.95rem;margin-bottom:14px;text-align:center;}
        .filtros{display:flex;gap:8px;overflow-x:auto;padding:12px 16px;scrollbar-width:none;}
        .filtro-btn{background:var(--tarjeta);border:1.5px solid var(--verde-medio);color:var(--texto);padding:7px 16px;border-radius:20px;font-size:0.82rem;font-weight:600;cursor:pointer;white-space:nowrap;}
        .filtro-btn.activo{background:var(--dorado);color:var(--fondo);border-color:var(--dorado);}
        .partido-card{background:var(--tarjeta);border-radius:12px;padding:16px 16px 16px 20px;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;border-left:4px solid var(--verde-medio);cursor:pointer;}
        .partido-card:hover{background:var(--tarjeta-hover);}
        .partido-grupo{display:inline-block;background:var(--verde-oscuro);color:var(--dorado);font-size:0.7rem;font-weight:700;padding:2px 8px;border-radius:4px;margin-bottom:8px;}
        .partido-equipos{font-size:1rem;font-weight:700;margin-bottom:6px;}
        .partido-info{font-size:0.78rem;color:var(--texto-muted);line-height:1.7;}
        .partido-arrow{color:var(--dorado);font-size:1.6rem;margin-left:12px;}
        .detalle-vs{background:linear-gradient(to bottom,var(--verde-oscuro),var(--verde-medio));border-radius:16px;padding:28px 20px;text-align:center;margin-bottom:16px;}
        .detalle-vs .equipo{font-size:1.4rem;font-weight:800;}
        .detalle-vs .vs{color:var(--dorado);font-size:1.1rem;font-weight:800;margin:6px 0;}
        .detalle-row{background:var(--tarjeta);border-radius:10px;padding:14px 16px;margin-bottom:10px;display:flex;align-items:center;gap:14px;}
        .detalle-row .emoji{font-size:1.3rem;}
        .detalle-row .label{font-size:0.75rem;color:var(--texto-muted);}
        .detalle-row .valor{font-size:0.95rem;font-weight:600;}
        .btn-comprar{width:100%;background:var(--dorado);color:var(--fondo);border:none;border-radius:12px;padding:16px;font-size:1rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;}
        .volver{display:inline-block;color:var(--dorado);font-weight:700;font-size:0.9rem;padding:14px 16px 4px;cursor:pointer;}
        .sector-option{background:var(--tarjeta);border:2px solid transparent;border-radius:10px;padding:14px 16px;margin-bottom:8px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;}
        .sector-option.seleccionado{border-color:var(--dorado);background:rgba(255,193,7,0.08);}
        .sector-nombre{font-weight:700;font-size:0.95rem;}
        .sector-desc{font-size:0.75rem;color:var(--texto-muted);}
        .sector-badge{background:var(--verde-medio);color:#fff;font-size:0.72rem;font-weight:700;padding:3px 8px;border-radius:6px;}
        .sector-precio{color:var(--dorado);font-weight:700;}
        .cantidad-control{display:flex;align-items:center;gap:16px;margin:12px 0;}
        .cantidad-btn{background:var(--verde-medio);border:none;color:#fff;width:38px;height:38px;border-radius:8px;font-size:1.3rem;cursor:pointer;font-weight:700;}
        .cantidad-num{font-size:1.3rem;font-weight:700;min-width:32px;text-align:center;}
        .total-box{background:linear-gradient(to right,var(--verde-oscuro),var(--verde-medio));border-radius:10px;padding:14px 16px;display:flex;justify-content:space-between;align-items:center;margin:16px 0;}
        .total-label{font-size:0.85rem;color:rgba(255,255,255,0.75);}
        .total-valor{font-size:1.3rem;font-weight:800;color:var(--dorado);}
        .ticket-card{background:var(--dorado);border-radius:12px;padding:16px;margin-bottom:10px;color:var(--fondo);}
        .ticket-grupo{font-size:0.75rem;font-weight:700;}
        .ticket-sector{background:var(--verde-oscuro);color:#fff;font-size:0.72rem;font-weight:700;padding:2px 8px;border-radius:5px;margin-left:6px;}
        .ticket-equipos{font-size:1rem;font-weight:800;margin:8px 0 6px;}
        .ticket-info{font-size:0.78rem;opacity:0.8;line-height:1.8;}
        .tickets-resumen{background:linear-gradient(to bottom,var(--verde-oscuro),var(--verde-medio));border-radius:12px;padding:16px 20px;margin-bottom:16px;display:flex;justify-content:space-between;}
        .res-label{font-size:0.82rem;color:rgba(255,255,255,0.75);}
        .res-valor{font-size:1.3rem;font-weight:800;color:var(--dorado);text-align:right;}
    </style>
</head>
<body>
    @RenderBody()
</body>
</html>
