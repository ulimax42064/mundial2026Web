@model TUPMundial.Web.Models.Partido
@{ ViewData["Title"] = "Comprar"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="header" style="padding: 16px 20px 20px;">
    <div class="header-left">
            <span style="font-size:1.6rem;">⚽</span>
                    <div class="header-title" style="font-size:1.15rem;">Comprar Entrada</div>
                        </div>
                        </div>
                        <div class="header-strip"></div>
                        <a href="/Partidos/Detalle/@Model.Id" class="volver">← Volver</a>

                        <div class="container" style="padding-top:12px;">
                            @if (ViewBag.Error != null)
                                { <div class="alerta-error">@ViewBag.Error</div> }

                                    <div class="detalle-vs" style="margin-bottom:16px;">
                                            <div class="equipo">@Model.Flag1 @Model.Equipo1</div>
                                                    <div class="vs">VS</div>
                                                            <div class="equipo">@Model.Equipo2 @Model.Flag2</div>
                                                                </div>

                                                                    <div class="detalle-row"><div class="emoji">📅</div><div><div class="label">FECHA</div><div class="valor">@Model.Fecha</div></div></div>
                                                                        <div class="detalle-row"><div class="emoji">🏟</div><div><div class="label">ESTADIO</div><div class="valor">@Model.Estadio</div></div></div>
                                                                            <div class="detalle-row"><div class="emoji">🏆</div><div><div class="label">GRUPO</div><div class="valor">@Model.Grupo</div></div></div>

                                                                                <form method="post" action="/Tickets/Comprar">
                                                                                        <input type="hidden" name="partidoId"  value="@Model.Id" />
                                                                                                <input type="hidden" name="sector"      id="sectorInput"     value="" />
                                                                                                        <input type="hidden" name="precioUnit"  id="precioUnitInput" value="" />
                                                                                                                <input type="hidden" name="cantidad"    id="cantidadInput"   value="1" />

                                                                                                                        <!-- Cantidad -->
                                                                                                                                <div class="detalle-row" style="flex-direction:column; align-items:flex-start; gap:8px;">
                                                                                                                                            <div class="label">CANTIDAD DE ENTRADAS</div>
                                                                                                                                                        <div class="cantidad-control">
                                                                                                                                                                        <button type="button" class="cantidad-btn" onclick="cambiar(-1)">−</button>
                                                                                                                                                                                        <div class="cantidad-num" id="cantidadDisplay">1</div>
                                                                                                                                                                                                        <button type="button" class="cantidad-btn" onclick="cambiar(1)">+</button>
                                                                                                                                                                                                                    </div>
                                                                                                                                                                                                                            </div>

                                                                                                                                                                                                                                    <!-- Sectores -->
                                                                                                                                                                                                                                            <div class="label" style="padding: 4px 2px 10px; letter-spacing:1px;">SECTOR / UBICACIÓN</div>
                                                                                                                                                                                                                                                    @{
                                                                                                                                                                                                                                                                var sectores = new[] {
                                                                                                                                                                                                                                                                                new { Nombre="Popular",   Desc="Acceso general, de pie", Precio=120m, Badge="-19%" },
                                                                                                                                                                                                                                                                                                new { Nombre="Platea",    Desc="Asiento numerado",       Precio=200m, Badge="Base" },
                                                                                                                                                                                                                                                                                                                new { Nombre="Platinium", Desc="Vista premium",          Precio=320m, Badge="+VIP" },
                                                                                                                                                                                                                                                                                                                                new { Nombre="VIP",       Desc="Zona exclusiva",         Precio=480m, Badge="VIP"  },
                                                                                                                                                                                                                                                                                                                                            };
                                                                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                                                                            @foreach (var s in sectores)
                                                                                                                                                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                                                                                                                                                                <div class="sector-option" onclick="seleccionar(this, '@s.Nombre', @s.Precio)">
                                                                                                                                                                                                                                                                                                                                                                                                <div>
                                                                                                                                                                                                                                                                                                                                                                                                                    <div class="sector-nombre">@s.Nombre</div>
                                                                                                                                                                                                                                                                                                                                                                                                                                        <div class="sector-desc">@s.Desc</div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                        </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <div style="display:flex; align-items:center; gap:8px;">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <span class="sector-badge">@s.Badge</span>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <span class="sector-precio">$@s.Precio</span>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <div class="total-box">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <div class="total-label">Total a pagar</div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <div style="font-size:0.78rem; color:rgba(255,255,255,0.5);" id="totalDesc">— Seleccioná un sector</div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <div class="total-valor" id="totalDisplay">$ —</div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        </div>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <button type="submit" class="btn-comprar">🎟 Confirmar compra</button>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    </form>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    </div>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    <script>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        let cantidad = 1, precio = 0;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            function cambiar(d) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    cantidad = Math.min(10, Math.max(1, cantidad + d));
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            document.getElementById('cantidadDisplay').textContent = cantidad;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    document.getElementById('cantidadInput').value = cantidad;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            actualizar();
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    function seleccionar(el, nombre, p) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            document.querySelectorAll('.sector-option').forEach(s => s.classList.remove('seleccionado'));
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    el.classList.add('seleccionado');
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            precio = p;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    document.getElementById('sectorInput').value = nombre;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            document.getElementById('precioUnitInput').value = p;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    actualizar();
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            function actualizar() {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    if (!precio) return;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            document.getElementById('totalDisplay').textContent = '$ ' + (precio * cantidad).toFixed(2);
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    document.getElementById('totalDesc').textContent = cantidad + ' entrada' + (cantidad > 1 ? 's' : '') + ' × $' + precio;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        </script>